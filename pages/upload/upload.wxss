/* pages/upload/upload.wxss */

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 0;
  box-sizing: border-box;
}

/* 顶部标题区域 */
.header-section {
  text-align: center;
  padding: 120rpx 40rpx 80rpx 40rpx;
  color: white;
}

.app-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  display: block;
}

.app-title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  display: block;
}

.app-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
  display: block;
}

/* 主要内容区域 */
.main-section {
  flex: 1;
  padding: 0 40rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* 预览区域 */
.preview-section {
  width: 100%;
  max-width: 600rpx;
  margin: 0 auto;
}

.preview-card {
  background-color: white;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 40rpx;
}

.preview-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 24rpx;
}

.preview-image {
  width: 100%;
  height: 300rpx;
  border-radius: 12rpx;
  display: block;
  margin-bottom: 24rpx;
  background-color: #f5f5f5;
}

.preview-notice {
  font-size: 28rpx;
  color: #07c160;
  text-align: center;
  margin-bottom: 32rpx;
  font-weight: 500;
}

.preview-actions {
  display: flex;
  gap: 20rpx;
}

.reselect-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.analyze-btn {
  flex: 2;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.analyze-btn.disabled {
  background-color: #ccc !important;
  color: #999 !important;
}

/* 操作按钮区域 */
.actions-section {
  width: 100%;
  max-width: 600rpx;
  margin: 0 auto;
}

.primary-actions {
  margin-bottom: 40rpx;
}

.main-action-btn {
  width: 100%;
  height: 140rpx;
  border-radius: 20rpx;
  font-size: 36rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.3);
}

.btn-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.btn-icon {
  font-size: 48rpx;
  display: block;
}

.btn-text {
  font-size: 28rpx;
  display: block;
}

.secondary-actions {
  display: flex;
  gap: 24rpx;
}

.demo-btn, .history-btn {
  flex: 1;
  height: 120rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.demo-btn {
  background-color: #ff976a;
  color: white;
}

.history-btn {
  background-color: transparent;
  color: #1989fa;
  border: 2rpx solid #1989fa;
}

.agent-entry-btn {
  margin-top: 28rpx;
  width: 100%;
  min-height: 116rpx;
  border-radius: 20rpx;
  background: rgba(255, 248, 231, 0.94);
  border: 2rpx solid rgba(178, 122, 48, 0.2);
  color: #513114;
}

.agent-entry-inner {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  align-items: flex-start;
  text-align: left;
}

.agent-entry-badge {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: #b26b20;
}

.agent-entry-text {
  font-size: 26rpx;
  line-height: 1.5;
}

/* 底部说明区域 */
.footer-section {
  padding: 60rpx 40rpx 120rpx 40rpx;
  color: white;
}

.tips-section {
  margin-bottom: 40rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.tip-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  min-width: 40rpx;
}

.tip-text {
  font-size: 26rpx;
  opacity: 0.9;
}

.version-info {
  text-align: center;
  font-size: 24rpx;
  opacity: 0.7;
}

/* 按钮通用样式增强 */
.btn {
  border-radius: 12rpx;
  font-size: 32rpx;
  line-height: 1.4;
  border: none;
  outline: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.btn:active {
  transform: scale(0.98);
}

.btn-primary {
  background: linear-gradient(135deg, #07c160 0%, #00a854 100%);
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.btn-secondary {
  background-color: #ff976a;
  color: white;
}

.btn-outline {
  background-color: transparent;
  border: 2rpx solid currentColor;
}

.btn-primary:hover, .btn-secondary:hover {
  opacity: 0.9;
}

/* 响应式适配 */
@media (max-width: 750rpx) {
  .container {
    padding: 0 20rpx;
  }

  .header-section {
    padding: 80rpx 20rpx 60rpx 20rpx;
  }

  .main-section {
    padding: 0 20rpx;
  }

  .footer-section {
    padding: 40rpx 20rpx 80rpx 20rpx;
  }
}
