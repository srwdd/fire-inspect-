# ── 拍照查隐患 — Vision LLM 配置 ──────────────────────────
# 四选一，取消注释即可切换

# 方案 A：通义千问 Qwen-VL（推荐，100万tokens/月免费）
# 获取Key: https://dashscope.console.aliyun.com/apiKey
# SILICONFLOW_API_KEY=sk-your-key
# SILICONFLOW_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# VISION_MODEL=qwen-vl-max

# 方案 B：DeepSeek（文本对话正常，但不支持图片分析）
# SILICONFLOW_API_KEY=sk-your-key
# SILICONFLOW_BASE_URL=https://api.deepseek.com/v1
# VISION_MODEL=deepseek-chat

# 方案 C：Kimi (Moonshot)
# SILICONFLOW_API_KEY=sk-your-key
# SILICONFLOW_BASE_URL=https://api.moonshot.cn/v1
# VISION_MODEL=moonshot-v1-8k-vision-preview

# 方案 D：硅基流动 SiliconFlow
# SILICONFLOW_API_KEY=sk-your-key
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# VISION_MODEL=Qwen/Qwen3-VL-30B-A3B-Instruct
