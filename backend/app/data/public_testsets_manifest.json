      "hazard_mapping": [
        "open_set_non_fire_distractor",
        "equipment_visibility_and_occlusion"
      ]
    },
    {
      "id": "detectium_fire",
      "name": "DetectiumFire",
      "domain": "multimodal_fire_reasoning",
      "modality": ["image", "video", "text"],
      "scale": {
        "images": 22500,
        "videos": 2500
      },
      "license_note": "Released by authors via linked dataset page (Kaggle).",
