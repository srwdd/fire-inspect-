      "license_note": "Open Images license and attribution rules apply.",
      "source": {
        "dataset": "https://storage.googleapis.com/openimages/web/factsfigures_v7.html",
        "release_blog": "https://research.google/blog/open-images-v7-now-featuring-point-labels/"
      },
      "key_notes": [
        "Useful for open-set distractor and long-tail object robustness.",
