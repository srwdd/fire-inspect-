      "hazard_mapping": [
        "ppe_missing_helmet",
        "ppe_missing_vest",
        "industrial_operation_risk"
      ]
    },
    {
      "id": "open_images_v7",
      "name": "Open Images V7",
      "domain": "large_scale_open_world_detection",
      "modality": ["image", "text"],
      "scale": {
        "images": 9000000,
        "dense_subset_images": 1900000
