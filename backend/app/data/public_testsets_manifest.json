      "license_note": "Follow contest rules for data usage and redistribution.",
      "source": {
        "dataset": "https://mivia.unisa.it/onfire2025/"
      },
      "key_notes": [
        "Scenario-level difficulty tags (LA-SR, LA-LR, HA-LR, HA-SR).",
        "Uses fire-start instant annotation, supports latency-aware metrics."
      ],
      "hazard_mapping": [
        "fire_smoke_visible",
        "early_warning_latency"
      ]
    },
    {
      "id": "shwd",
