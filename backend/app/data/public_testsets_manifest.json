{
  "version": "2026-04-19",
  "datasets": [
    {
      "id": "dfire",
      "name": "D-Fire",
      "domain": "fire_and_smoke_detection",
      "modality": ["image"],
      "scale": {
        "images": 21527,
        "fire_boxes": 14692,
        "smoke_boxes": 11865
      },
      "license_note": "Check repository LICENSE before redistribution.",
      "source": {
        "dataset": "https://github.com/gaia-solutions-on-demand/DFireDataset"
      },
      "key_notes": [
        "Contains positive and negative scenes for robust detection.",
        "Provides pre-split train/val/test links and YOLO labels."
      ],
      "hazard_mapping": [
        "fire_smoke_visible",
        "combustible_near_heat_source",
        "electrical_overload_or_aging"
      ]
    },
    {
      "id": "mivia_fire_detection",
      "name": "MIVIA Fire Detection Dataset",
      "domain": "video_fire_smoke_detection",
      "modality": ["video"],
      "scale": {
        "videos": 31,
        "positive_videos": 14,
        "negative_videos": 17
      },
      "license_note": "Research use; follow MIVIA access requirements.",
      "source": {
        "dataset": "https://mivia.unisa.it/datasets/video-analysis-datasets/fire-detection-dataset/"
      },
      "key_notes": [
        "Negative set includes hard distractors such as red moving objects and cloud-like patterns.",
        "Suitable for false-positive stress testing."
      ],
      "hazard_mapping": [
        "fire_smoke_visible",
        "open_set_non_fire_distractor"
      ]
    },
    {
      "id": "onfire_2025",
      "name": "ONFIRE Contest 2025 Dataset",
      "domain": "video_early_fire_detection",
      "modality": ["video"],
      "scale": {
