      "hazard_mapping": [
        "ppe_missing_helmet",
        "construction_site_compliance"
      ]
    },
    {
      "id": "sh17",
      "name": "SH17 PPE Dataset",
      "domain": "industrial_ppe_detection",
      "modality": ["image"],
      "scale": {
        "images": 8099,
        "instances": 75994,
        "classes": 17
      },
      "license_note": "CC BY-NC-SA 4.0; verify non-commercial restriction for releases.",
      "source": {
        "dataset": "https://github.com/ahmadmughees/SH17dataset"
      },
      "key_notes": [
        "Includes helmet, vest, gloves, face protection and tool-related classes.",
